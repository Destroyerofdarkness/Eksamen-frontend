<%- include("./partials/head.ejs")  %>
<link rel="stylesheet" href="/css/auth.css">
<script src="/script/fetch_login.js" defer></script>
<%- include("./partials/header.ejs")  %>

<form>
    <label for="username">Brukernavn:</label>
    <input type="text" name="username" id="username" placeholder="Enter your username..">
    <div class="error user"></div>
    <label for="passwd">Passord:</label>
    <input type="password" name="passwd" id="passwd" placeholder="Enter your password..">
    <div class="error passwd"></div>
    <button type="submit">Logg Inn</button>
     <a href="/signUp">Har ikke en Bruker?</a>
</form>

</body>
</html>